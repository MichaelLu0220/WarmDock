# 本地 Supabase 讀的 OAuth 憑證(供 config.toml 的 env() 代換)。
# 複製成 supabase/.env,填入從 Google Cloud Console 取得的值,然後重啟:
#   pnpm supabase stop && pnpm supabase start
# (CLI 會自動載入 supabase/.env;若沒有,改用 `supabase start --env-file supabase/.env`)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
